# Local development only. Do not set this in GitHub Pages builds.
VITE_SPORTRADAR_API_KEY=
VITE_SPORTRADAR_ACCESS_LEVEL=trial
VITE_SPORTRADAR_LANGUAGE=en
VITE_FIBA_DEFAULT_COMPETITION_ID=sr:competition:17788
VITE_FIBA_DEFAULT_SEASON_ID=

# Public FIBA deployments should usually leave accounts disabled.
# Set to true only if you intentionally want to reuse account-backed features.
VITE_ENABLE_ACCOUNTS=false

# Required for deployed builds that should fetch data through the Supabase sportradar-proxy function.
# Optional for purely local dev if you use VITE_SPORTRADAR_API_KEY instead.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
